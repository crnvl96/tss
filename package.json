{
  "name": "tss",
  "version": "0.1.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsgo",
    "start": "node dist/main.js",
    "dev": "tsgo --watch",
    "typecheck": "tsgo --noEmit -p tsconfig.test.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "quality": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:logs": "docker compose logs -f postgres",
    "db:init": "node --env-file=.env scripts/db-init.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@hono/zod-validator": "^0.8.0",
    "@huggingface/transformers": "^4.2.0",
    "@temporalio/activity": "^1.19.0",
    "@temporalio/client": "^1.19.0",
    "@temporalio/worker": "^1.19.0",
    "@temporalio/workflow": "^1.19.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "markdown-it": "^14.3.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@typescript/native-preview": "^7.0.0-dev.20260703.1",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "pino-pretty": "^13.1.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24"
  }
}
